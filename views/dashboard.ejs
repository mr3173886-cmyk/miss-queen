<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Miss Queen 💟 - Dashboard</title>
  <style>
    body, html, div, h2, h3, p, video, button, pre {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    body {
      background: #0f0f1a;
      color: #fff;
      display: flex;
      height: 100vh;
      overflow: hidden;
    }
    .sidebar {
      width: 250px;
      background: #151528;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      flex-direction: column;
      padding: 20px;
    }
    .sidebar h2 {
      color: #ff69b4;
      text-align: center;
      margin-bottom: 5px;
    }
    .sidebar p.credits {
      text-align: center;
      font-size: 0.75em;
      color: #ccc;
      margin-bottom: 30px;
    }
    .nav-btn {
      width: 100%;
      padding: 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      text-align: left;
      border-radius: 8px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }
    .nav-btn:hover, .nav-btn.active {
      background: #ff69b4;
      border-color: #ff69b4;
    }
    .admin-link {
      margin-top: auto;
      background: #4a154b;
      border-color: #ff69b4;
      text-align: center;
    }
    .main-content {
      flex: 1;
      padding: 40px;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      position: relative;
    }
    .header-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }
    .logout-btn {
      padding: 8px 16px;
      background: #ff4d4d;
      border: none;
      border-radius: 5px;
      color: #fff;
      text-decoration: none;
      font-size: 0.9em;
    }
    .video-container {
      width: 100%;
      max-width: 600px;
      margin: 0 auto 30px auto;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    video {
      width: 100%;
      display: block;
    }
    .script-viewer {
      background: #151528;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 20px;
      display: none;
    }
    .script-viewer h3 {
      color: #ff69b4;
      margin-bottom: 15px;
    }
    pre {
      background: #0f0f1a;
      padding: 15px;
      border-radius: 8px;
      overflow-x: auto;
      color: #00ffcc;
      font-family: 'Courier New', Courier, monospace;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <h2>Miss Queen 💟</h2>
    <p class="credits">Made by 💖 𝔐𝔯.𝔎𝔦𝔫𝔤</p>
    
    <div id="script-list">
      <% if (scripts.length === 0) { %>
        <p style="text-align: center; color: #777; font-size: 0.9em;">No scripts uploaded yet.</p>
      <% } else { %>
        <% scripts.forEach(script => { %>
          <button class="nav-btn" onclick="showScript('<%= script._id %>', '<%= script.name %>')">
            <%= script.name %>
          </button>
        <% }) %>
      <% } %>
    </div>

    <% if (user.role === 'admin') { %>
      <button class="nav-btn admin-link" onclick="location.href='/admin'">Admin Panel</button>
    <% } %>
  </div>

  <div class="main-content">
    <div class="header-bar">
      <h3>Welcome, <%= user.username %></h3>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>

    <div class="video-container">
      <video id="autoplay-video" autoplay loop muted playsinline>
        <source src="https://files.catbox.moe/14ind4.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </div>

    <div class="script-viewer" id="viewer">
      <h3 id="script-title">Script Name</h3>
      <pre><code id="script-code"></code></pre>
    </div>
  </div>

  <script>
    // Browser auto-play block bypass
    document.body.addEventListener('click', () => {
      const video = document.getElementById('autoplay-video');
      if (video) {
        video.muted = false;
      }
    }, { once: true });

    const scriptsData = <%- JSON.stringify(scripts) %>;

    function showScript(id, name) {
      const script = scriptsData.find(s => s._id === id);
      if (script) {
        document.getElementById('viewer').style.display = 'block';
        document.getElementById('script-title').innerText = name;
        document.getElementById('script-code').innerText = script.code;
      }
    }
  </script>
</body>
</html>

