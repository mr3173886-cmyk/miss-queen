<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Miss Queen 💟 - Dashboard</title>
  <style>
    body, html, div, h2, h3, p, video, button, pre {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    body {
      background: #0f0f1a;
      color: #fff;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      overflow-y: auto;
    }
    @media (min-width: 768px) {
      body {
        flex-direction: row;
        height: 100vh;
        overflow: hidden;
      }
    }
    .sidebar {
      width: 100%;
      background: #151528;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      flex-direction: column;
      padding: 20px;
    }
    @media (min-width: 768px) {
      .sidebar {
        width: 250px;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: none;
        height: 100%;
      }
    }
    .sidebar h2 {
      color: #ff69b4;
      text-align: center;
      margin-bottom: 5px;
    }
    .sidebar p.credits {
      text-align: center;
      font-size: 0.75em;
      color: #ccc;
      margin-bottom: 20px;
    }
    .nav-btn {
      width: 100%;
      padding: 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      text-align: left;
      border-radius: 8px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }
    .nav-btn:hover, .nav-btn.active {
      background: #ff69b4;
      border-color: #ff69b4;
    }
    .admin-link {
      margin-top: 10px;
      background: #4a154b;
      border-color: #ff69b4;
      text-align: center;
    }
    @media (min-width: 768px) {
      .admin-link {
        margin-top: auto;
      }
    }
    .main-content {
      flex: 1;
      padding: 20px;
      display: flex;
      flex-direction: column;
    }
    @media (min-width: 768px) {
      .main-content {
        padding: 40px;
        overflow-y: auto;
      }
    }
    .header-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
    .logout-btn {
      padding: 8px 16px;
      background: #ff4d4d;
      border: none;
      border-radius: 5px;
      color: #fff;
      text-decoration: none;
      font-size: 0.9em;
    }
    .video-container {
      width: 100%;
      max-width: 600px;
      margin: 0 auto 20px auto;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    video {
      width: 100%;
      display: block;
    }
    .script-viewer {
      background: #151528;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 20px;
      display: none;
    }
    .script-viewer h3 {
      color: #ff69b4;
      margin-bottom: 15px;
    }
    pre {
      background: #0f0f1a;
      padding: 15px;
      border-radius: 8px;
      overflow-x: auto;
      color: #00ffcc;
      font-family: 'Courier New', Courier, monospace;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <h2>Miss Queen 💟</h2>
    <p class="credits">Made by 💖 𝔐𝔯.𝔎𝔦𝔫𝔤</p>
    
    <div id="script-list">
      <% if (scripts.length === 0) { %>
        <p style="text-align: center; color: #777; font-size: 0.9em;">No scripts uploaded yet.</p>
      <% } else { %>
        <% scripts.forEach(script => { %>
          <button class="nav-btn" onclick="showScript('<%= script._id %>', '<%= script.name %>')">
            <%= script.name %>
          </button>
        <% }) %>
      <% } %>
    </div>

    <% if (user.role === 'admin') { %>
      <button class="nav-btn admin-link" onclick="location.href='/admin'">Admin Panel</button>
    <% } %>
  </div>

  <div class="main-content">
    <div class="header-bar">
      <h3>Welcome, <%= user.username %></h3>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>

    <div class="video-container">
      <video id="autoplay-video" autoplay loop muted playsinline>
        <source src="https://files.catbox.moe/14ind4.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </div>

    <div class="script-viewer" id="viewer">
      <h3 id="script-title">Script Name</h3>
      <div id="script-code"></div>
    </div>
  </div>

  <script>
    // Browser auto-play block bypass
    document.body.addEventListener('click', () => {
      const mainVideo = document.getElementById('autoplay-video');
      if (mainVideo) {
        mainVideo.muted = false;
      }
    }, { once: true });

    const scriptsData = <%- JSON.stringify(scripts) %>;

    async function showScript(id, name) {
      const script = scriptsData.find(s => s._id === id);
      if (!script) return;

      const viewer = document.getElementById('viewer');
      const title = document.getElementById('script-title');
      const codeArea = document.getElementById('script-code');

      viewer.style.display = 'block';
      title.innerText = name;

      const lowerName = name.toLowerCase();
      const isAnime = lowerName.includes('anime');
      const isBaby = lowerName.includes('baby') || lowerName.includes('bby') || lowerName.includes('chat');
      const isShayari = lowerName.includes('shayari');

      if (isAnime) {
        codeArea.innerHTML = `
          <div style="text-align: center; padding: 10px;">
            <p id="anime-status" style="color: #ff69b4; margin-bottom: 10px; font-weight: bold;">🎬 Fetching random anime edit for you...</p>
            <div id="video-wrapper" style="display: none; max-width: 350px; margin: 0 auto; border-radius: 10px; overflow: hidden; box-shadow: 0 0 15px rgba(255, 105, 180, 0.5);">
              <video id="anime-player" controls autoplay style="width: 100%; display: block;"></video>
            </div>
            <button onclick="loadNextAnime()" style="margin-top: 15px; padding: 10px 20px; background: #ff1493; border: none; border-radius: 8px; color: #fff; cursor: pointer; font-weight: bold;">Next Video ⏭️</button>
          </div>
        `;
        loadNextAnime();
      } else if (isShayari) {
        codeArea.innerHTML = `
          <div style="text-align: center; padding: 10px;">
            <p id="shayari-status" style="color: #ff69b4; margin-bottom: 10px; font-weight: bold;">🎬 একটু অপেক্ষা করো বেবি😜...</p>
            <div id="shayari-wrapper" style="display: none; max-width: 350px; margin: 0 auto; border-radius: 10px; overflow: hidden; box-shadow: 0 0 15px rgba(255, 105, 180, 0.5);">
              <video id="shayari-player" controls autoplay style="width: 100%; display: block;"></video>
            </div>
            <button onclick="loadNextShayari()" style="margin-top: 15px; padding: 10px 20px; background: #ff1493; border: none; border-radius: 8px; color: #fff; cursor: pointer; font-weight: bold;">Next Shayari ⏭️</button>
          </div>
        `;
        loadNextShayari();
      } else if (isBaby) {
        codeArea.innerHTML = `
          <div style="display: flex; flex-direction: column; height: 380px; background: #0f0f26; border-radius: 10px; border: 1px solid #ff69b4; overflow: hidden;">
            <div style="background: linear-gradient(135deg, #ff1493, #ff69b4); padding: 10px; display: flex; align-items: center; gap: 8px;">
              <div style="width: 8px; height: 8px; background: #00ff00; border-radius: 50%;"></div>
              <span style="font-weight: bold; font-size: 0.9rem; color: white;">Hinata Chat (bby) 🎀</span>
            </div>
            <div id="chat-box-messages" style="flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px;">
              <div style="align-self: flex-start; background: rgba(255,255,255,0.08); padding: 8px 12px; border-radius: 12px 12px 12px 0px; color: #ff69b4; font-size: 0.85rem; max-width: 80%;">
                Bolo baby, how can I help you? 😘
              </div>
            </div>
            <div style="padding: 10px; background: #151528; display: flex; gap: 6px; border-top: 1px solid rgba(255,255,255,0.1);">
              <input id="chat-box-input" type="text" placeholder="Type a message..." style="flex: 1; padding: 8px 12px; border-radius: 20px; border: 1px solid #ff69b4; background: #0f0f26; color: white; outline: none; font-size: 0.85rem;" />
              <button id="chat-box-send-btn" style="background: #ff1493; border: none; color: white; width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;">🕊️</button>
            </div>
          </div>
        `;
        setupChatBox();
      } else {
        codeArea.innerHTML = `<pre><code>${escapeHtml(script.code)}</code></pre>`;
      }
    }

    async function loadNextShayari() {
      const statusText = document.getElementById('shayari-status');
      const wrapper = document.getElementById('shayari-wrapper');
      const player = document.getElementById('shayari-player');

      if (statusText) {
        statusText.style.display = 'block';
        statusText.innerText = "একটু অপেক্ষা করো বেবি😜...";
      }
      if (wrapper) wrapper.style.display = 'none';

      try {
        const baseRes = await fetch('https://raw.githubusercontent.com/Sh4nDev/ShAn.s-Api/refs/heads/main/Api.json');
        const baseData = await baseRes.json();
        const shanBase = baseData.shan;

        const targetUrl = `${shanBase}/ShAn-album-videos?category=shayari&senderID=10001&author=ShAn`;

        const response = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(targetUrl)}`);
        const proxyData = await response.json();
        const data = JSON.parse(proxyData.contents);

        if (data && data.ShAn) {
          player.src = data.ShAn;
          if (statusText) statusText.style.display = 'none';
          if (wrapper) wrapper.style.display = 'block';
        } else {
          if (statusText) statusText.innerText = "❌ ভুল এপিআই রেস্পন্স..";
        }
      } catch (err) {
        console.error(err);
        if (statusText) statusText.innerText = "⚠ ভিডিও লোড করা যায়নি। আবার চেষ্টা করুন!";
      }
    }

    async function loadNextAnime() {
      const statusText = document.getElementById('anime-status');
      const wrapper = document.getElementById('video-wrapper');
      const player = document.getElementById('anime-player');

      if (statusText) {
        statusText.style.display = 'block';
        statusText.innerText = "🎬 Fetching random anime edit...";
      }
      if (wrapper) wrapper.style.display = 'none';

      const tags = [
        "anime attitude edit 4k", "anime sigma male edit", "badass anime moments edit",
        "anime cold moments edit", "anime villain attitude edit", "anime phonk edit badass",
        "anime savage moments", "anime walk attitude edit", "anime death stare edit",
        "anime dark aesthetic edit", "madara uchiha attitude edit", "gojo satoru badass edit",
        "eren yeager freedom edit", "itachi uchiha cold edit", "sukuna ryoamen attitude",
        "levi ackerman badass edit", "daiki aomine attitude"
      ];

      try {
        const mul = (num, multiplier) => num / (1 / multiplier);
        const randomIndex = Math.floor(mul(Math.random(), tags.length));
        const randomTag = tags[randomIndex];

        const response = await fetch("https://www.tikwm.com/api/feed/search?keywords=" + encodeURIComponent(randomTag));
        const data = await response.json();
        const videos = data?.data?.videos;

        if (videos && videos.length > 0) {
          const randomVidIndex = Math.floor(mul(Math.random(), videos.length));
          const selectedVideo = videos[randomVidIndex];
          const videoUrl = selectedVideo.play || selectedVideo.hdplay;

          if (videoUrl) {
            player.src = videoUrl;
            if (statusText) statusText.style.display = 'none';
            if (wrapper) wrapper.style.display = 'block';
          } else {
            if (statusText) statusText.innerText = "⚠️ Video link not found. Click Next Video!";
          }
        } else {
          if (statusText) statusText.innerText = "⚠️ No videos returned. Try again!";
        }
      } catch (err) {
        if (statusText) statusText.innerText = "⚠️ Connection error. Click Next Video!";
      }
    }

    function setupChatBox() {
      const chatInput = document.getElementById('chat-box-input');
      const sendBtn = document.getElementById('chat-box-send-btn');
      const messagesArea = document.getElementById('chat-box-messages');

      const mahmud = [
        "baby", "bby", "babu", "bbu", "jan", "bot", "জান", "জানু", "বেবি", "wifey", "hinata"
      ];

      const randomMessages = [
        "babu khuda lagse🥺", "Hop beda😾,Boss বল boss😼", "আমাকে ডাকলে ,আমি কিন্তূ কিস করে দেবো😘 ",
        "𝗜 𝗹𝗼𝐯𝗲 𝘆𝗼𝐮__😘😘", "𝗜 𝗵𝗮𝘁𝗲 𝘆𝗼𝐮__😏😏", "গোসল করে আসো যাও😑😩", "কেমন আছো_🥹",
        "বলেন sir__😌", "বলেন ম্যাডাম__😌", "𝗕𝗲𝘀𝗵𝗶 𝗱𝗮𝗸𝗹𝗲 𝗮𝗺ｍｕ 𝗯𝗼𝗸𝗮 𝗱ｉ𝐛𝗲 𝘁𝗼__🥺",
        "তোর কথা তোর বাড়ি কেউ শুনে না ,তো আমি কোনো শুনবো ?🤔😂", "আমি তো অন্ধ কিছু দেখি না🐸 😎",
        "আজব তো__😒", "আমাকে না ডেকে একটু পড়তেও বসতে তো পারো 😒😒", "তোর বিয়ে হয় নি 𝗕𝗯𝘆 হইলো কিভাবে,,🙄",
        "বলো ফুলটুশি_😘", "amr JaNu lagbe,Tumi ki single aso?🥹", "Meow🐤", "astagfirullah Ami Valo mey",
        "কি হলো, মিস টিস করতেছিস নাকি 🤣", "Bolo Babu, তুমি কি আমাকে ভালোবাসো? 🙈"
      ];

      const mul = (num, multiplier) => num / (1 / multiplier);

      async function getBaseApi() {
        try {
          const res = await fetch("https://raw.githubusercontent.com/mahmudx7/HINATA/main/baseApiUrl.json");
          const data = await res.json();
          return data.mahmud;
        } catch {
          return null;
        }
      }

      async function handleSend() {
        const text = chatInput.value.trim();
        if (!text) return;

        appendMsg(text, 'user');
        chatInput.value = '';

        const typingId = appendMsg("Thinking...", 'bot', true);
        const lowerText = text.toLowerCase();
        const hasWord = mahmud.some(word => lowerText.startsWith(word));
        const wordsCount = lowerText.split(/\s+/).length;

        if (hasWord && wordsCount === 1) {
          const randomMsg = randomMessages[Math.floor(mul(Math.random(), randomMessages.length))];
          removeTyping(typingId);
          appendMsg(randomMsg, 'bot');
          return;
        }

        try {
          const baseUrl = await getBaseApi();
          if (!baseUrl) {
            removeTyping(typingId);
            appendMsg("API connection error janu 🥹", 'bot');
            return;
          }

          let cleanedText = text;
          for (const prefix of mahmud) {
            if (lowerText.startsWith(prefix)) {
              cleanedText = text.substring(prefix.length).trim();
              break;
            }
          }

          const response = await fetch(`${baseUrl}/api/hinata`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ text: cleanedText, style: 3, attachments: [] })
          });
          const resData = await response.json();

          removeTyping(typingId);
          if (resData && resData.message) {
            appendMsg(resData.message, 'bot');
          } else {
            appendMsg("error janu🥹", 'bot');
          }
        } catch (err) {
          removeTyping(typingId);
          appendMsg("error janu🥹", 'bot');
        }
      }

      function appendMsg(text, sender, isTyping = false) {
        const id = 'msg-' + Date.now();
        const bubble = document.createElement('div');
        bubble.id = id;
        bubble.style.maxWidth = "80%";
        bubble.style.padding = "8px 12px";
        bubble.style.borderRadius = sender === 'user' ? "12px 12px 0px 12px" : "12px 12px 12px 0px";
        bubble.style.fontSize = "0.85rem";
        bubble.style.lineHeight = "1.3";

        if (sender === 'user') {
          bubble.style.alignSelf = "flex-end";
          bubble.style.background = "#ff69b4";
          bubble.style.color = "white";
        } else {
          bubble.style.alignSelf = "flex-start";
          bubble.style.background = "rgba(255,255,255,0.08)";
          bubble.style.color = isTyping ? "#888" : "#fff";
        }

        bubble.innerText = text;
        messagesArea.appendChild(bubble);
        messagesArea.scrollTop = messagesArea.scrollHeight;
        return id;
      }

      function removeTyping(id) {
        const el = document.getElementById(id);
        if (el) el.remove();
      }

      sendBtn.addEventListener('click', handleSend);
      chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleSend();
      });
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }
  </script>
</body>
</html>
